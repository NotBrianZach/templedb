#!/usr/bin/env bash
# templedb dev wrapper
#
# PYTHON:       resolved from ./result (nix build output — has fastapi/uvicorn/python-multipart)
# PYTHONPATH:   from ~/.nix-profile/bin/templedb if available, else ./result (fallback)
#
# Resilience: if ./result is missing, falls back to cached nix store path,
# then tries auto-rebuild. Avoids hard dependency on ~/templeDB/result existing.

DIR="$(cd "$(dirname "$0")" && pwd)"
RESULT="$DIR/result"
CACHE_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/templedb/last-result"

if [ ! -L "$RESULT" ]; then
  # Fallback 1: use cached nix store path from last successful run
  if [ -f "$CACHE_FILE" ] && [ -d "$(cat "$CACHE_FILE")" ]; then
    RESULT="$(cat "$CACHE_FILE")"
    echo "Warning: $DIR/result missing, using cached build at $RESULT" >&2
  else
    # Fallback 2: try to auto-rebuild
    echo "Warning: $DIR/result missing, attempting nix build..." >&2
    if (cd "$DIR" && nix build .#templedb --no-update-lock-file 2>&1); then
      RESULT="$DIR/result"
    else
      echo "Error: $DIR/result symlink not found and auto-rebuild failed." >&2
      echo "  Run manually: cd $DIR && nix build .#templedb --no-update-lock-file" >&2
      exit 1
    fi
  fi
fi

# Cache the resolved nix store path for future fallback
_resolved="$(readlink -f "$RESULT" 2>/dev/null)"
if [ -n "$_resolved" ] && [ -d "$_resolved" ]; then
  mkdir -p "$(dirname "$CACHE_FILE")"
  echo "$_resolved" > "$CACHE_FILE"
fi

# Python from the local nix build (has all GUI deps)
PYTHON="$(grep -m1 'exec "' "$RESULT/bin/templedb" | sed 's|.*exec "\(.*\)/bin/python3".*|\1/bin/python3|')"
if [ -z "$PYTHON" ] || [ ! -x "$PYTHON" ]; then
  echo "Error: could not resolve python3 from $RESULT/bin/templedb" >&2
  exit 1
fi

# PYTHONPATH: prefer home-manager install (may have extra modules), fall back to ./result
PROFILE_TEMPLEDB="$(readlink -f ~/.nix-profile/bin/templedb 2>/dev/null)"
if [ -n "$PROFILE_TEMPLEDB" ] && [ -f "$PROFILE_TEMPLEDB" ]; then
  SYSTEM_SITE="$(grep -m1 'PYTHONPATH=' "$PROFILE_TEMPLEDB" | sed "s|.*PYTHONPATH='\\(.*\\)'.*|\\1|")"
fi
if [ -z "$SYSTEM_SITE" ]; then
  # Fall back to ./result site-packages (works when home-manager not yet switched)
  SYSTEM_SITE="$(grep -m1 'PYTHONPATH=' "$RESULT/bin/templedb" | sed "s|.*PYTHONPATH='\\(.*\\)'.*|\\1|")"
fi

# cr-sqlite extension path (from nix build)
CRSQLITE="$(grep -m1 'TEMPLEDB_CRSQLITE_PATH=' "$RESULT/bin/templedb" 2>/dev/null | sed "s|.*TEMPLEDB_CRSQLITE_PATH='\\(.*\\)'.*|\\1|")"
if [ -z "$CRSQLITE" ]; then
  CRSQLITE="$RESULT/lib/crsqlite"
fi

exec env PYTHONPATH="$SYSTEM_SITE" PYTHONNOUSERSITE=true \
  TEMPLEDB_CRSQLITE_PATH="$CRSQLITE" \
  "$PYTHON" "$DIR/templedb_launcher.py" "$@"
