#!/usr/bin/env bash
# templedb dev wrapper
#
# Uses the new Python env (has fastapi/uvicorn built-in) but keeps PYTHONPATH
# pointing at the system-installed templedb package, which has the real
# NixOSCommand base class that src/cli/commands/nixos.py patches.
#
# To regenerate after a NixOS rebuild:
#   cat $(which templedb)   # find new PYTHON path
#   update SYSTEM_SITE below if the system package hash changed

PYTHON="/nix/store/y54m7d1kw30kj93wpsaiyk6gmd7qhlkd-python3-3.13.13-env/bin/python3"
SYSTEM_SITE="/nix/store/3pldkw59m4n8p6dlpajhpa30s79libp5-templedb-0.1.0/lib/python3.13/site-packages"

exec env PYTHONPATH="$SYSTEM_SITE" PYTHONNOUSERSITE=true \
  "$PYTHON" /home/zach/templeDB/templedb_launcher.py "$@"
