#!/usr/bin/env bash
# tdb - TempleDB CLI wrapper
#
# Delegates to the full Python CLI (templedb).
# If installed via nix, uses the nix-built binary.
# Otherwise, falls back to running python3 -m cli from source.

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Find the templedb binary
if [ -x "$SCRIPT_DIR/result/bin/templedb" ]; then
    exec "$SCRIPT_DIR/result/bin/templedb" "$@"
elif command -v templedb &>/dev/null; then
    # Installed via nix (in PATH)
    exec templedb "$@"
else
    # Fallback: run from source
    cd "$SCRIPT_DIR"
    exec python3 -m cli "$@"
fi
